{
  "name": "fijiboundless",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute fijiboundless --local --file=database/schema.sql",
    "db:init:remote": "wrangler d1 execute fijiboundless --file=database/schema.sql",
    "db:seed": "wrangler d1 execute fijiboundless --local --file=database/seed.sql",
    "db:seed:remote": "wrangler d1 execute fijiboundless --file=database/seed.sql",
    "db:locations": "wrangler d1 execute fijiboundless --local --file=database/locations.sql",
    "db:locations:remote": "wrangler d1 execute fijiboundless --file=database/locations.sql",
    "pages:dev": "wrangler pages dev dist --d1=DB=fijiboundless",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0"
  }
}
